{
  "uid": "bada-infrastructure",
  "title": "BADA Infrastructure",
  "tags": ["bada", "infrastructure"],
  "timezone": "Asia/Seoul",
  "templating": {
    "list": []
  },
  "panels": [
    {
      "id": 1,
      "title": "Backend CPU %",
      "type": "timeseries",
      "gridPos": {"h": 8, "w": 12, "x": 0, "y": 0},
      "datasource": {"type": "cloudwatch", "uid": "cloudwatch"},
      "targets": [{
        "refId": "A",
        "namespace": "AWS/ECS",
        "metricName": "CPUUtilization",
        "statistic": "Average",
        "metricQueryType": 0,
        "metricEditorMode": 0,
        "period": "60",
        "dimensions": {"ClusterName": ["${ecs_cluster}"], "ServiceName": ["${backend_service}"]},
        "matchExact": true,
        "region": "${aws_region}"
      }],
      "fieldConfig": {"defaults": {"unit": "percent", "max": 100}}
    },
    {
      "id": 2,
      "title": "Backend Memory %",
      "type": "timeseries",
      "gridPos": {"h": 8, "w": 12, "x": 12, "y": 0},
      "datasource": {"type": "cloudwatch", "uid": "cloudwatch"},
      "targets": [{
        "refId": "A",
        "namespace": "AWS/ECS",
        "metricName": "MemoryUtilization",
        "statistic": "Average",
        "metricQueryType": 0,
        "metricEditorMode": 0,
        "period": "60",
        "dimensions": {"ClusterName": ["${ecs_cluster}"], "ServiceName": ["${backend_service}"]},
        "matchExact": true,
        "region": "${aws_region}"
      }],
      "fieldConfig": {"defaults": {"unit": "percent", "max": 100}}
    },
    {
      "id": 3,
      "title": "Worker CPU %",
      "type": "timeseries",
      "gridPos": {"h": 8, "w": 12, "x": 0, "y": 8},
      "datasource": {"type": "cloudwatch", "uid": "cloudwatch"},
      "targets": [{
        "refId": "A",
        "namespace": "AWS/ECS",
        "metricName": "CPUUtilization",
        "statistic": "Average",
        "metricQueryType": 0,
        "metricEditorMode": 0,
        "period": "60",
        "dimensions": {"ClusterName": ["${ecs_cluster}"], "ServiceName": ["${worker_service}"]},
        "matchExact": true,
        "region": "${aws_region}"
      }],
      "fieldConfig": {"defaults": {"unit": "percent", "max": 100}}
    },
    {
      "id": 4,
      "title": "Worker Memory %",
      "type": "timeseries",
      "gridPos": {"h": 8, "w": 12, "x": 12, "y": 8},
      "datasource": {"type": "cloudwatch", "uid": "cloudwatch"},
      "targets": [{
        "refId": "A",
        "namespace": "AWS/ECS",
        "metricName": "MemoryUtilization",
        "statistic": "Average",
        "metricQueryType": 0,
        "metricEditorMode": 0,
        "period": "60",
        "dimensions": {"ClusterName": ["${ecs_cluster}"], "ServiceName": ["${worker_service}"]},
        "matchExact": true,
        "region": "${aws_region}"
      }],
      "fieldConfig": {"defaults": {"unit": "percent", "max": 100}}
    },
    {
      "id": 5,
      "title": "RDS CPU %",
      "type": "timeseries",
      "gridPos": {"h": 8, "w": 8, "x": 0, "y": 16},
      "datasource": {"type": "cloudwatch", "uid": "cloudwatch"},
      "targets": [{
        "refId": "A",
        "namespace": "AWS/RDS",
        "metricName": "CPUUtilization",
        "statistic": "Average",
        "metricQueryType": 0,
        "metricEditorMode": 0,
        "period": "300",
        "dimensions": {"DBInstanceIdentifier": ["${rds_instance_id}"]},
        "matchExact": true,
        "region": "${aws_region}"
      }],
      "fieldConfig": {"defaults": {"unit": "percent", "max": 100}}
    },
    {
      "id": 6,
      "title": "RDS Connections",
      "type": "timeseries",
      "gridPos": {"h": 8, "w": 8, "x": 8, "y": 16},
      "datasource": {"type": "cloudwatch", "uid": "cloudwatch"},
      "targets": [{
        "refId": "A",
        "namespace": "AWS/RDS",
        "metricName": "DatabaseConnections",
        "statistic": "Average",
        "metricQueryType": 0,
        "metricEditorMode": 0,
        "period": "60",
        "dimensions": {"DBInstanceIdentifier": ["${rds_instance_id}"]},
        "matchExact": true,
        "region": "${aws_region}"
      }],
      "fieldConfig": {"defaults": {"unit": "short"}}
    },
    {
      "id": 7,
      "title": "RDS Free Storage",
      "type": "stat",
      "gridPos": {"h": 8, "w": 8, "x": 16, "y": 16},
      "datasource": {"type": "cloudwatch", "uid": "cloudwatch"},
      "targets": [{
        "refId": "A",
        "namespace": "AWS/RDS",
        "metricName": "FreeStorageSpace",
        "statistic": "Average",
        "metricQueryType": 0,
        "metricEditorMode": 0,
        "period": "300",
        "dimensions": {"DBInstanceIdentifier": ["${rds_instance_id}"]},
        "matchExact": true,
        "region": "${aws_region}"
      }],
      "fieldConfig": {"defaults": {"unit": "bytes"}}
    },
    {
      "id": 8,
      "title": "ALB 5xx Count",
      "type": "timeseries",
      "gridPos": {"h": 8, "w": 12, "x": 0, "y": 24},
      "datasource": {"type": "cloudwatch", "uid": "cloudwatch"},
      "targets": [
        {
          "refId": "A",
          "namespace": "AWS/ApplicationELB",
          "metricName": "HTTPCode_Target_5XX_Count",
          "statistic": "Sum",
          "metricQueryType": 0,
          "metricEditorMode": 0,
          "period": "60",
          "dimensions": {"LoadBalancer": ["${alb_arn_suffix}"]},
          "matchExact": true,
          "region": "${aws_region}",
          "label": "5xx"
        },
        {
          "refId": "B",
          "namespace": "AWS/ApplicationELB",
          "metricName": "HTTPCode_Target_4XX_Count",
          "statistic": "Sum",
          "metricQueryType": 0,
          "metricEditorMode": 0,
          "period": "60",
          "dimensions": {"LoadBalancer": ["${alb_arn_suffix}"]},
          "matchExact": true,
          "region": "${aws_region}",
          "label": "4xx"
        }
      ]
    },
    {
      "id": 9,
      "title": "ALB Request Count",
      "type": "timeseries",
      "gridPos": {"h": 8, "w": 12, "x": 12, "y": 24},
      "datasource": {"type": "cloudwatch", "uid": "cloudwatch"},
      "targets": [{
        "refId": "A",
        "namespace": "AWS/ApplicationELB",
        "metricName": "RequestCount",
        "statistic": "Sum",
        "metricQueryType": 0,
        "metricEditorMode": 0,
        "period": "60",
        "dimensions": {"LoadBalancer": ["${alb_arn_suffix}"]},
        "matchExact": true,
        "region": "${aws_region}"
      }]
    },
    {
      "id": 10,
      "title": "SQS Messages Visible",
      "type": "timeseries",
      "gridPos": {"h": 8, "w": 12, "x": 0, "y": 32},
      "datasource": {"type": "cloudwatch", "uid": "cloudwatch"},
      "targets": [
        {
          "refId": "A",
          "namespace": "AWS/SQS",
          "metricName": "ApproximateNumberOfMessagesVisible",
          "statistic": "Average",
          "metricQueryType": 0,
          "metricEditorMode": 0,
          "period": "60",
          "dimensions": {"QueueName": ["${sqs_queue_name}"]},
          "matchExact": true,
          "region": "${aws_region}",
          "label": "Main Queue"
        },
        {
          "refId": "B",
          "namespace": "AWS/SQS",
          "metricName": "ApproximateNumberOfMessagesVisible",
          "statistic": "Average",
          "metricQueryType": 0,
          "metricEditorMode": 0,
          "period": "60",
          "dimensions": {"QueueName": ["${sqs_dlq_name}"]},
          "matchExact": true,
          "region": "${aws_region}",
          "label": "DLQ"
        }
      ]
    },
    {
      "id": 11,
      "title": "SQS Oldest Message Age",
      "type": "timeseries",
      "gridPos": {"h": 8, "w": 12, "x": 12, "y": 32},
      "datasource": {"type": "cloudwatch", "uid": "cloudwatch"},
      "targets": [{
        "refId": "A",
        "namespace": "AWS/SQS",
        "metricName": "ApproximateAgeOfOldestMessage",
        "statistic": "Maximum",
        "metricQueryType": 0,
        "metricEditorMode": 0,
        "period": "60",
        "dimensions": {"QueueName": ["${sqs_queue_name}"]},
        "matchExact": true,
        "region": "${aws_region}"
      }],
      "fieldConfig": {"defaults": {"unit": "s"}}
    }
  ],
  "schemaVersion": 39,
  "version": 3
}
