# 복사해서 backend/.env 로 사용 (커밋 금지)
# 로컬은 아무것도 안 넣어도 동작(전부 Mock). AWS 기능을 켜려면 아래 참고.

# ---- DB ----
# Local SQLite: sqlite:///./bada.db
# RDS Postgres: postgresql+psycopg://USER:PASSWORD@RDS_ENDPOINT:5432/bada
DATABASE_URL=sqlite:///./bada.db
DATABASE_AUTO_CREATE=true
DATABASE_SSL_MODE=
DATABASE_POOL_SIZE=5
DATABASE_MAX_OVERFLOW=10

# ---- 모드 스위치 ----
# local = Mock(키 불필요) / aws = 실제 OCR·AI·번역
PROVIDER_MODE=local
# 정형문서 OCR 엔진: vision(기본·전부 Claude Vision) | upstage | parseur
STRUCTURED_ENGINE=vision
# AUTH_MODE=demo        # demo | cognito (인증 담당)
# STORAGE_MODE=local    # local | s3   (스토리지 담당)

# ====================================================================
# AWS 기능 켜기:  PROVIDER_MODE=aws 로 바꾸고 아래를 채운다.
#   - OCR(이미지)·AI 문장화 = Amazon Bedrock (Claude)
#   - OCR(정형문서)         = Upstage 또는 Parseur
#   - 번역                  = Amazon Translate
# boto3는 AWS 자격증명을 환경변수/`aws configure`/IAM 역할에서 자동으로 읽음.
# ====================================================================
AWS_REGION=ap-northeast-2
AWS_PROFILE=

# Bedrock (Claude) — 4.6 검증 모델 (3.5는 계정에서 legacy로 막힘)
BEDROCK_MODEL_ID=global.anthropic.claude-sonnet-4-6
BEDROCK_VISION_MODEL_ID=global.anthropic.claude-sonnet-4-6

# AI Chat
# mock: 템플릿 기반 로컬 답변
# bedrock: AWS Bedrock Claude 호출, 실패 시 mock fallback
AI_CHAT_MODE=mock
AI_CHAT_MAX_TOKENS=700

# AWS 자격증명 (aws configure 를 했다면 생략 가능)
# AWS_ACCESS_KEY_ID=
# AWS_SECRET_ACCESS_KEY=

# RAG
RAG_ENABLED=true
RAG_USE_VECTOR=true
RAG_TOP_K=4
RAG_MIN_KEYWORD_SCORE=1
EMBEDDING_MODE=mock
EMBEDDING_MODEL_ID=amazon.titan-embed-text-v2:0
EMBEDDING_DIMENSION=1024

# 정형문서 OCR (Upstage 외부 API — PII 마스킹 후 호출)
UPSTAGE_API_KEY=
PARSEUR_API_KEY=

# ---- (스토리지/인증 담당이 채움) ----
S3_BUCKET=bada-evidences-dev
KMS_KEY_ID=
SQS_QUEUE_URL=
TRANSCRIPTION_DISPATCH_MODE=inline

# Cognito
COGNITO_USER_POOL_ID=
COGNITO_CLIENT_ID=

RETENTION_DAYS=90
