# 복사해서 backend/.env 로 사용 (커밋 금지)
# 로컬은 아무것도 안 넣어도 동작(전부 Mock). AWS 기능을 켜려면 아래 참고.

# ---- DB ----
DATABASE_URL=sqlite:///./bada.db

# ---- 모드 스위치 ----
# local = Mock(키 불필요) / aws = 실제 OCR·AI·번역
PROVIDER_MODE=local
# 정형문서 OCR 엔진: vision(기본·전부 Claude Vision) | upstage | parseur
STRUCTURED_ENGINE=vision
# AUTH_MODE=demo        # demo | cognito (인증 담당)
# STORAGE_MODE=local    # local | s3   (스토리지 담당)

# ====================================================================
# AWS 기능 켜기:  PROVIDER_MODE=aws 로 바꾸고 아래를 채운다.
#   - OCR(이미지)·AI 문장화 = Amazon Bedrock (Claude)
#   - OCR(정형문서)         = Upstage 또는 Parseur
#   - 번역                  = Amazon Translate
# boto3는 AWS 자격증명을 환경변수/`aws configure`/IAM 역할에서 자동으로 읽음.
# ====================================================================
AWS_REGION=ap-northeast-2
BEDROCK_MODEL_ID=global.anthropic.claude-sonnet-4-6

# AWS 자격증명 (aws configure 를 했다면 생략 가능)
# AWS_ACCESS_KEY_ID=
# AWS_SECRET_ACCESS_KEY=

# 정형문서 OCR (둘 중 STRUCTURED_ENGINE 로 선택한 것의 키)
UPSTAGE_API_KEY=
PARSEUR_API_KEY=

# ---- (스토리지/인증 담당이 채움) ----
S3_BUCKET=
KMS_KEY_ID=
SQS_QUEUE_URL=
COGNITO_USER_POOL_ID=
COGNITO_CLIENT_ID=

RE