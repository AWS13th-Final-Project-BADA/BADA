# 복사해서 .env 로 사용 (커밋 금지)

# DB
DATABASE_URL=postgresql+psycopg://bada:bada@localhost:5432/bada

# AWS
AWS_REGION=ap-northeast-2
S3_BUCKET=bada-evidences-dev
KMS_KEY_ID=
SQS_QUEUE_URL=

# Bedrock (Claude)
BEDROCK_MODEL_ID=anthropic.claude-3-5-sonnet-20241022-v2:0
BEDROCK_VISION_MODEL_ID=anthropic.claude-3-5-sonnet-20241022-v2:0

# Upstage (외부 API — PII 마스킹 후 호출)
UPSTAGE_API_KEY=

# Cognito
COGNITO_USER_POOL_ID=
COGNITO_CLIENT_ID=

# 데이터 보존(일)
RETENTION_DAYS=90
