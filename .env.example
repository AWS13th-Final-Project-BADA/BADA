# 복사해서 .env 로 사용 (커밋 금지)

# DB
DATABASE_URL=postgresql+psycopg://bada:bada@localhost:5432/bada

# AWS
AWS_REGION=ap-northeast-2
AWS_PROFILE=
S3_BUCKET=bada-evidences-dev
KMS_KEY_ID=
SQS_QUEUE_URL=

# Bedrock (Claude)
BEDROCK_MODEL_ID=anthropic.claude-3-5-sonnet-20241022-v2:0
BEDROCK_VISION_MODEL_ID=anthropic.claude-3-5-sonnet-20241022-v2:0

# AI Chat
# mock: 템플릿 기반 로컬 답변
# bedrock: AWS Bedrock Claude 호출, 실패 시 mock fallback
AI_CHAT_MODE=mock
AI_CHAT_MAX_TOKENS=700

# Upstage (외부 API — PII 마스킹 후 호출)
UPSTAGE_API_KEY=

# Cognito
COGNITO_USER_POOL_ID=
COGNITO_CLIENT_ID=

# 데이터 보존(일)
RETENTION_DAYS=90
