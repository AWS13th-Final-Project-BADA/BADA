# 복사해서 backend/.env 로 사용
# 주의: backend/.env 는 커밋 금지(.gitignore 처리). 실제 키/secret은 이 파일에 넣지 않는다.

# ====================================================================
# 1) 로컬 기본 모드
# ====================================================================
# DB를 아직 안 붙였거나 로컬에서 빠르게 테스트할 때:
# DATABASE_URL=sqlite:///./bada.db
# DATABASE_AUTO_CREATE=true
# PROVIDER_MODE=local
# AI_CHAT_MODE=mock
# EMBEDDING_MODE=mock

# ====================================================================
# 2) 실제 AWS 모드 (OCR/요약/번역/챗봇/RAG 실동작)
# ====================================================================

# ---- DB (RDS private 접속: SSM 포트포워딩 localhost:15432) ----
DATABASE_URL=postgresql+psycopg://bada_admin:<DB_PASSWORD>@localhost:15432/bada
DATABASE_AUTO_CREATE=false
DATABASE_SSL_MODE=require
DATABASE_POOL_SIZE=5
DATABASE_MAX_OVERFLOW=10

# ---- 모드 스위치 ----
# local = Mock / aws = 실제 AWS Bedrock·Translate·OCR 흐름
PROVIDER_MODE=aws
# vision = 정형문서도 Claude Vision 처리 / upstage = Upstage OCR 사용 / parseur = Parseur 사용
STRUCTURED_ENGINE=vision

# ---- AWS / Bedrock ----
AWS_REGION=ap-northeast-2
AWS_PROFILE=
BEDROCK_MODEL_ID=global.anthropic.claude-sonnet-4-6
BEDROCK_VISION_MODEL_ID=global.anthropic.claude-sonnet-4-6

# ---- AI Chat ----
# mock = 템플릿 기반 로컬 답변 / bedrock = AWS Bedrock Claude 호출
AI_CHAT_MODE=bedrock
AI_CHAT_MAX_TOKENS=700

# ---- RAG / Embedding ----
RAG_ENABLED=true
RAG_USE_VECTOR=true
RAG_TOP_K=4
RAG_MIN_KEYWORD_SCORE=1
RAG_MODE=local
EMBEDDING_MODE=bedrock
EMBEDDING_MODEL_ID=amazon.titan-embed-text-v2:0
EMBEDDING_DIMENSION=1024

# ---- Optional OCR provider ----
# Upstage 정형 OCR를 쓰려면 STRUCTURED_ENGINE=upstage 로 바꾸고 키 입력.
UPSTAGE_API_KEY=
PARSEUR_API_KEY=

# ---- Auth / Social Login ----
AUTH_JWT_ENABLED=true
APP_BASE_URL=http://localhost:8000
JWT_SECRET=<LONG_RANDOM_SECRET>
JWT_EXPIRE_MINUTES=10080

# Kakao
KAKAO_REST_API_KEY=
KAKAO_CLIENT_SECRET=
KAKAO_REDIRECT_URI=http://localhost:8000/auth/kakao/callback

# Google
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GOOGLE_REDIRECT_URI=http://localhost:8000/auth/google/callback

# Naver
NAVER_CLIENT_ID=
NAVER_CLIENT_SECRET=
NAVER_REDIRECT_URI=http://localhost:8000/auth/naver/callback

# ---- Storage / Infra ----
AUTH_MODE=oauth
STORAGE_MODE=local
UPLOAD_DIR=./uploads
S3_BUCKET=bada-evidences-dev
KMS_KEY_ID=
SQS_QUEUE_URL=
COGNITO_USER_POOL_ID=
COGNITO_CLIENT_ID=
COGNITO_CLIENT_SECRET=
COGNITO_DOMAIN=
COGNITO_REDIRECT_URI=http://localhost:8000/auth/cognito/callback
COGNITO_LOGOUT_URI=http://localhost:8000/
COGNITO_SCOPES=openid email profile
RETENTION_DAYS=90
