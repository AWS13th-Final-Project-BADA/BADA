{
  "name": "bada-mobile-native",
  "version": "0.1.0",
  "private": true,
  "description": "BADA 네이티브 모바일 앱 (React Native + Expo). 웹뷰가 아닌 진짜 네이티브 앱.",
  "main": "expo-router/entry",
  "scripts": {
    "start": "expo start",
    "android": "expo run:android",
    "ios": "expo run:ios",
    "web": "expo start --web",
    "lint": "expo lint",
    "check:i18n": "node scripts/check-i18n-encoding.mjs"
  },
  "dependencies": {
    "@react-native-async-storage/async-storage": "1.23.1",
    "expo": "~51.0.0",
    "expo-constants": "~16.0.0",
    "expo-document-picker": "~12.0.0",
    "expo-image-picker": "~15.0.0",
    "expo-linking": "~6.3.0",
    "expo-localization": "~15.0.0",
    "expo-location": "~17.0.0",
    "expo-media-library": "^56.0.7",
    "expo-router": "~3.5.0",
    "expo-secure-store": "~13.0.0",
    "expo-status-bar": "~1.12.0",
    "expo-task-manager": "~11.8.0",
    "expo-web-browser": "~13.0.0",
    "i18n-js": "^4.4.3",
    "react": "18.2.0",
    "react-native": "0.74.5",
    "react-native-safe-area-context": "4.10.5",
    "react-native-screens": "3.31.1"
  },
  "devDependencies": {
    "@babel/core": "^7.24.0",
    "@types/react": "~18.2.79",
    "typescript": "~5.3.3"
  },
  "allowScripts": {
    "fsevents@2.3.3": true
  }
}
