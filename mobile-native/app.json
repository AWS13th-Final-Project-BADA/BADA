{
  "expo": {
    "name": "BADA",
    "slug": "bada-mobile-native",
    "scheme": "bada",
    "version": "0.1.0",
    "orientation": "portrait",
    "userInterfaceStyle": "light",
    "splash": {
      "backgroundColor": "#2563eb",
      "resizeMode": "contain"
    },
    "assetBundlePatterns": ["**/*"],
    "ios": {
      "supportsTablet": false,
      "bundleIdentifier": "com.bada.app",
      "infoPlist": {
        "NSLocationWhenInUseUsageDescription": "근무지 출입 증거 수집을 위해 위치를 사용합니다.",
        "NSLocationAlwaysAndWhenInUseUsageDescription": "재직 중 근무 증거를 위해 백그라운드에서도 위치를 수집합니다.",
        "UIBackgroundModes": ["location"],
        "NSCameraUsageDescription": "증거 문서 촬영을 위해 카메라를 사용합니다.",
        "NSPhotoLibraryUsageDescription": "증거 이미지 업로드를 위해 사진 접근이 필요합니다."
      }
    },
    "android": {
      "package": "com.bada.app",
      "permissions": [
        "ACCESS_COARSE_LOCATION",
        "ACCESS_FINE_LOCATION",
        "ACCESS_BACKGROUND_LOCATION",
        "FOREGROUND_SERVICE",
        "FOREGROUND_SERVICE_LOCATION",
        "CAMERA",
        "READ_MEDIA_IMAGES"
      ]
    },
    "plugins": [
      "expo-router",
      "expo-secure-store",
      [
        "expo-location",
        {
          "locationAlwaysAndWhenInUsePermission": "재직 중 근무 증거를 위해 백그라운드에서도 위치를 수집합니다.",
          "isAndroidBackgroundLocationEnabled": true,
          "isAndroidForegroundServiceEnabled": true
        }
      ],
      "expo-image-picker"
    ],
    "extra": {
      "apiBase": "https://api.badasoft.com",
      "router": { "origin": false }
    }
  }
}
