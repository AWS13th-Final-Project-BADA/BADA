project_name         = "bada"
environment          = "dev"
aws_region           = "ap-northeast-2"
vpc_cidr             = "10.0.0.0/16"
public_subnet_cidrs  = ["10.0.1.0/24", "10.0.2.0/24"]
private_subnet_cidrs = ["10.0.11.0/24", "10.0.12.0/24"]
db_username          = "bada_admin"
db_password          = "change-me"
db_instance_class    = "db.t4g.micro"
db_allocated_storage = 20
app_port             = 8000
log_retention_days   = 14
api_container_image  = "123456789012.dkr.ecr.ap-northeast-2.amazonaws.com/bada-api:latest"
worker_container_image = "123456789012.dkr.ecr.ap-northeast-2.amazonaws.com/bada-worker:latest"
