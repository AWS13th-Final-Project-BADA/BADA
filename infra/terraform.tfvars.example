project_name         = "bada"
environment          = "dev"
aws_region           = "ap-northeast-2"
vpc_cidr             = "10.0.0.0/16"
public_subnet_cidrs  = ["10.0.1.0/24", "10.0.2.0/24"]
private_subnet_cidrs = ["10.0.11.0/24", "10.0.12.0/24"]
db_username          = "bada_admin"
db_password          = "change-me"
db_instance_class    = "db.t4g.micro"
db_allocated_storage = 20

# Mentor feedback: keep Single-AZ but add minimum RDS data protection.
db_backup_retention_period   = 7
db_deletion_protection       = true
db_skip_final_snapshot       = false
db_final_snapshot_identifier = "bada-dev-postgres-final-snapshot"
db_apply_immediately         = true

app_port             = 8000
log_retention_days   = 14

# Cognito Hosted UI / OAuth authorization code grant.
cognito_domain_prefix = "bada-dev-165749212250"
cognito_callback_urls = ["http://localhost:8000/auth/cognito/callback"]
cognito_logout_urls   = ["http://localhost:8000/"]
cognito_oauth_scopes  = ["openid", "email", "profile"]

# Google OAuth credentials must stay in the ignored terraform.tfvars file.
# Google redirect URI:
# https://bada-dev-165749212250.auth.ap-northeast-2.amazoncognito.com/oauth2/idpresponse
enable_google_identity_provider = false
google_oauth_client_id           = "replace-me.apps.googleusercontent.com"
google_oauth_client_secret       = "replace-me"

# Worker queue runtime settings.
# 15-minute visibility timeout covers the current 10-minute transcription timeout with a buffer.
sqs_visibility_timeout_seconds = 900
sqs_receive_wait_time_seconds  = 20

# Use "replace-me" to let Terraform use the ECR repositories created in this stack.
api_container_image    = "replace-me"
worker_container_image = "replace-me"
frontend_container_image = "replace-me"

# ECS service desired count.
# Keep 0 until backend/worker images are pushed to ECR.
backend_desired_count = 0
worker_desired_count  = 0
frontend_desired_count = 0

# Minimum Fargate task size for dev/MVP.
backend_task_cpu    = 256
backend_task_memory = 512
worker_task_cpu     = 256
worker_task_memory  = 512
frontend_task_cpu   = 256
frontend_task_memory = 512
ecs_cpu_architecture = "ARM64"

# Frontend ECS/ECR/ALB resources. Enable infrastructure first with
# frontend_desired_count=0, push the first image, then raise it to 1.
domain_name      = ""
frontend_enabled = false

# CloudWatch alarm notifications.
# alarm_email_endpoints creates email subscriptions on the Terraform-managed SNS topic.
# Each recipient must confirm the AWS SNS subscription email before notifications are delivered.
alarm_email_endpoints = []

# Optional: add existing SNS topic ARNs or other action ARNs if the team already owns one.
alarm_actions = []

# Cost-safe defaults. Switch to aws/bedrock modes only when the team is ready.
backend_provider_mode  = "local"
backend_ai_chat_mode   = "mock"
backend_embedding_mode = "mock"
# inline: backend task handles audio transcription directly.
# sqs: backend sends transcription messages to SQS; requires a running worker consumer.
backend_transcription_dispatch_mode = "inline"
# Transcribe can use AWS independently while OCR/Bedrock remain local/mock.
backend_transcribe_mode = "aws"
worker_provider_mode     = "local"
worker_transcribe_mode   = "aws"
worker_translate_mode    = "local"
worker_structured_engine = "vision"

# Optional Prometheus + Grafana stack.
# When password is null, Terraform generates it and stores it in Secrets Manager.
monitoring_enabled      = false
grafana_admin_password  = null

# GitHub Actions OIDC deploy role scope.
github_owner         = "AWS13th-Final-Project-BADA"
github_repository    = "BADA"
github_deploy_branch = "develop"
