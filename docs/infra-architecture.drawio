        <!-- SSM EC2 -> RDS -->
        <mxCell id="conn-ssm-rds" value="port forward" style="edgeStyle=orthogonalEdgeStyle;rounded=1;orthogonalLoop=1;jettySize=auto;exitX=0.5;exitY=1;entryX=0.25;entryY=0;fontColor=#333333;fontSize=10;dashed=1;" edge="1" source="ssm-ec2" target="rds" parent="1">
          <mxGeometry relative="1" as="geometry" />
        </mxCell>

        <!-- ACM -> ALB -->
        <mxCell id="conn-acm-alb" style="edgeStyle=orthogonalEdgeStyle;rounded=1;orthogonalLoop=1;jettySize=auto;exitX=1;exitY=0.5;entryX=0;entryY=0.5;dashed=1;strokeColor=#DD344C;" edge="1" source="acm" target="alb" parent="1">
          <mxGeometry relative="1" as="geometry" />
