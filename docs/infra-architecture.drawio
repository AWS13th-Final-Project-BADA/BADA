        <!-- S3 Evidence -> KMS -->
        <mxCell id="conn-s3-kms" value="encrypt" style="edgeStyle=orthogonalEdgeStyle;rounded=1;orthogonalLoop=1;jettySize=auto;exitX=1;exitY=0.5;entryX=0;entryY=0.5;fontColor=#333333;fontSize=10;dashed=1;" edge="1" source="s3-evidence" target="kms" parent="1">
