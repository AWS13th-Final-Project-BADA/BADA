        <!-- ===== Legend ===== -->
        <mxCell id="legend" value="BADA Infrastructure Architecture&#xa;Region: ap-northeast-2 (Seoul) | Managed by: Terraform&#xa;&#xa;VPC-internal: ALB, ECS Fargate, RDS&#xa;Region-level (outside VPC): S3, SQS, Cognito, KMS, CloudWatch, ECR, Bedrock, Transcribe" style="text;html=1;strokeColor=#666666;fillColor=#f5f5f5;align=left;verticalAlign=top;whiteSpace=wrap;rounded=1;fontSize=11;fontStyle=0;fontColor=#333333;" vertex="1" parent="1">
