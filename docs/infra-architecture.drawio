          <mxGeometry relative="1" as="geometry" />
        </mxCell>

        <!-- CloudWatch -> SNS -->
        <mxCell id="conn-cw-sns" value="alarm" style="edgeStyle=orthogonalEdgeStyle;rounded=1;orthogonalLoop=1;jettySize=auto;exitX=1;exitY=0.5;entryX=0;entryY=0.5;fontColor=#333333;fontSize=10;" edge="1" source="cloudwatch" target="sns" parent="1">
          <mxGeometry relative="1" as="geometry" />
